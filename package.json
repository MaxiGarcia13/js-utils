{
  "name": "@maxigarcia/js-utils",
  "type": "module",
  "version": "1.2.0",
  "description": "JavaScript Utility Functions",
  "author": "Maximiliano Garcia Mortigliengo",
  "license": "ISC",
  "homepage": "https://github.com/MaxiGarcia13/js-utils#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaxiGarcia13/js-utils.git"
  },
  "bugs": {
    "url": "https://github.com/MaxiGarcia13/js-utils/issues"
  },
  "keywords": [
    "javascript",
    "typescript",
    "utilities"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "build": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prepublish:npm": "npm run build",
    "publish:npm": "npm publish --access public",
    "test": "vitest"
  },
  "devDependencies": {
    "@maxigarcia/eslint-config": "^1.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
